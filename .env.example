# ---- Teamup ----
# Request an API key at https://apidocs.teamup.com/ (Settings -> request a key).
# The calendar key/ID is the string in your calendar's share URL:
#   https://teamup.com/ksXXXXXXXXXXXX  ->  TEAMUP_CALENDAR_ID=ksXXXXXXXXXXXX
# Use an admin/modify key if you want webhooks; a read-only key is fine for the map.
TEAMUP_API_KEY=
TEAMUP_CALENDAR_ID=
TEAMUP_CALENDAR_NAME=Dispatch

# Optional additional calendars. Each gets an entry in a "Calendar" dropdown that
# swaps the whole map between them (own sub-calendars/crews/colors). Add _2, _3, …
# An entry reuses TEAMUP_API_KEY unless you set its own TEAMUP_API_KEY_<n>.
TEAMUP_CALENDAR_ID_2=
TEAMUP_CALENDAR_NAME_2=Production
TEAMUP_API_KEY_2=

# ---- Access control ----
# The dashboard has no login (it's a localhost-per-machine tool). If you bind it
# to a network address (e.g. --host 0.0.0.0 on an office LAN), non-localhost
# requests are REFUSED unless this token is set. Then reach it once as
#   http://<box-ip>:8000/?token=<DASHBOARD_TOKEN>   (it sets a cookie thereafter).
# Leave blank for the default localhost-only deployment.
DASHBOARD_TOKEN=
# Optional: if you register a Teamup webhook, gate it so randoms can't spam the
# poll loop. Register the URL as  https://.../webhook?t=<WEBHOOK_SECRET>
WEBHOOK_SECRET=

# ---- Geocoder ----
# nominatim = free OSM (~1 req/sec; weak on rural US residential addresses)
# census    = free US Census geocoder, no key, US-only, strong on rural addresses
# google    = needs GEOCODER_API_KEY (Geocoding API), best accuracy at scale
# mapbox    = needs GEOCODER_API_KEY
# May be a comma-separated fallback chain tried left-to-right, e.g.:
#   GEOCODER=census,nominatim   (recommended for US calendars)
GEOCODER=census,nominatim
GEOCODER_API_KEY=
NOMINATIM_EMAIL=you@example.com

# Region fence: a geocode landing OUTSIDE this lat/lng box goes to the "Unmapped"
# tray instead of dropping a pin — so a junk location ("Office", a street with no
# city) can't fling a job across the planet. Format: minlat,minlng,maxlat,maxlng.
# Default covers the Upper-Midwest service area; set GEO_BBOX= (blank) to disable.
GEO_BBOX=41,-91,48.5,-82

# ---- Routing (connecting line + distance/duration) ----
# osrm      = real driving routes via the free OSRM server (OSM ecosystem)
# haversine = straight-line fallback (no network)
# OSRM_URL  = swap to a self-hosted OSRM or another provider later
ROUTING=osrm
OSRM_URL=https://router.project-osrm.org

# ---- Polling / backfill ----
POLL_INTERVAL=20
BACKFILL_DAYS_PAST=7
BACKFILL_DAYS_FUTURE=60

# ---- Storage ----
DB_PATH=teamup_dispatch.db
# (The server binds to localhost only by design. To use a different port, set it
#  in the shell before launching — e.g.  PORT=9000 ./launch.sh  — not here.)

# ---- Demo: run with bundled sample data, no Teamup creds needed ----
DEMO=0

# ---- Weather warnings (US National Weather Service: free, no API key) ----
# Per-job risk badge on the map from api.weather.gov: official NWS alerts
# (watch/warning/advisory -> red) and a forecast for the job's time window
# (work-stoppers -> yellow). US-only, no signup. Set WEATHER=0 to turn it off.
WEATHER=1
# NWS asks every caller to send a contact (email or site URL) in the User-Agent.
# Blank falls back to NOMINATIM_EMAIL above. Please set a real one.
WEATHER_CONTACT=
# Only assess jobs starting within this many days (NWS forecasts run ~7 days).
WEATHER_HORIZON_DAYS=7
# Forecast thresholds that flag a job yellow during its time window:
WEATHER_RAIN_POP=50    # precipitation probability %  (any snow flags regardless)
WEATHER_WIND_MPH=20    # sustained wind mph
WEATHER_GUST_MPH=30    # wind gust mph
# Optional cold/heat flags for material cure/seal (blank = off, the default).
# For the "aggressive" heads-up, try WEATHER_COLD_F=20 and WEATHER_HEAT_F=90.
WEATHER_COLD_F=
WEATHER_HEAT_F=
# Backstop: max distinct job locations assessed per refresh on a cold cache
# (soonest jobs kept first) so a huge window can't fan out to NWS without bound.
WEATHER_MAX_POINTS=80
